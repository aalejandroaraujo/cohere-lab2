# Copy to .env and fill in from the Foundry portal.
# Both models are deployed under the SAME Foundry resource (Azure Direct /
# Global Standard), so they share ONE endpoint and ONE key. Only the model
# name differs per call.

FOUNDRY_ENDPOINT=https://<your-resource>.services.ai.azure.com
FOUNDRY_KEY=<your-api-key>

# Deployment names as shown in the Foundry Deployments view
EMBED_MODEL=embed-v-4-0
RERANK_MODEL=Cohere-rerank-v4.0-pro
